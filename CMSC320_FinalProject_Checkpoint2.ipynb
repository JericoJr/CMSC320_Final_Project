        "# extracts all the common columns between this dataset and the second dataset below\n",
        "df1 = df1[[\"Name\", \"Publisher\", \"Platform\", \"Genre\", \"Year_of_Release\", \"Global_Sales\", \"NA_Sales\", \"JP_Sales\", \"EU_Sales\", \"Other_Sales\", \"Critic_Score\"]]\n",
