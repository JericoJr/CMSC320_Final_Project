        "    'Name': 'game_name',\n",
        "    'Platform': 'platform',\n",
        "    'Genre': 'genre',\n",
        "    'Year_of_Release': 'release_year',\n",
        "    'Publisher': 'publisher',\n",
        "    'Developer': 'developer',\n",
        "    'Critic_Score': 'critic_score',\n",
        "    'Global_Sales': 'total_sales',\n",
        "    'NA_Sales': 'na_sales',\n",
