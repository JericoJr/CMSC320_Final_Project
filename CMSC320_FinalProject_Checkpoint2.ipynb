        "    'Other_Sales': 'other_sales',\n",
        "}\n",
        "\n",
        "# renames all the columns according to the renaming scheme\n",
        "df1 = df1.rename(columns=renaming_scheme)\n",
        "\n",
        "print(df1.dtypes)\n",
        "display(df1)\n"
